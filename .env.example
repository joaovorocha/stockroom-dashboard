# Environment Configuration Template
# Copy this file to .env and fill in your values

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Node environment (development, production, test)
NODE_ENV=production

# Server port
PORT=3000

# Force HTTPS redirect (recommended for production)
FORCE_HTTPS=true

# Application base URL (for email links, etc.)
APP_BASE_URL=https://your-domain.com

# Session secret (generate with: openssl rand -base64 32)
SESSION_SECRET=your-random-secret-here-change-this

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/stockroom_db

# Or individual components
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stockroom_db
DB_USER=stockroom_user
DB_PASSWORD=your-db-password

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# Gmail credentials for UPS email import
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# SMTP configuration (alternative to Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-password

# =============================================================================
# UPS EMAIL IMPORT
# =============================================================================

# Cron schedule for UPS email import
# Default: Every 30 minutes from 8am-8pm
UPS_EMAIL_IMPORT_CRON=0,30 8-19 * * *;0 20 * * *

# How many days back to check for emails
UPS_EMAIL_IMPORT_DAYS=2

# Delete emails after importing (true/false)
UPS_EMAIL_DELETE_AFTER_IMPORT=false

# =============================================================================
# EXTERNAL API INTEGRATIONS
# =============================================================================

# UPS API Credentials
UPS_CLIENT_ID=your-ups-client-id
UPS_CLIENT_SECRET=your-ups-client-secret
UPS_ACCOUNT_NUMBER=your-ups-account-number

# WaitWhile API
WAITWHILE_API_KEY=your-waitwhile-api-key
WAITWHILE_LOCATION_ID=your-location-id

# Manhattan Active API
MANHATTAN_CLIENT_ID=your-manhattan-client-id
MANHATTAN_CLIENT_SECRET=your-manhattan-client-secret
MANHATTAN_BASE_URL=https://ussbp.omni.manh.com

# PredictSpring API
PREDICTSPRING_API_KEY=your-predictspring-api-key

# Store Recovery / Product API
STORE_RECOVERY_PRODUCT_API_BASE_URL=https://api.example.com
STORE_RECOVERY_PRODUCT_API_KEY=your-api-key
STORE_RECOVERY_PRODUCT_API_KEY_HEADER=x-api-key
STORE_RECOVERY_PRODUCT_API_AUTH_TYPE=oauth2

# OAuth2 for Store Recovery API
STORE_RECOVERY_PRODUCT_OAUTH_DOMAIN=your-domain.com
STORE_RECOVERY_PRODUCT_OAUTH_TOKEN_URL=https://auth.example.com/oauth/token
STORE_RECOVERY_PRODUCT_OAUTH_CLIENT_ID=your-client-id
STORE_RECOVERY_PRODUCT_OAUTH_CLIENT_SECRET=your-client-secret
STORE_RECOVERY_PRODUCT_OAUTH_RESOURCE=https://api.example.com
STORE_RECOVERY_PRODUCT_OAUTH_SCOPE=api.read api.write
STORE_RECOVERY_PRODUCT_OAUTH_GRANT_TYPE=client_credentials
STORE_RECOVERY_PRODUCT_OAUTH_COUNTRY_CODE=US

# =============================================================================
# RADIO/SDR CONFIGURATION
# =============================================================================

# Radio monitor UDP settings
RADIO_MONITOR_UDP_HOST=127.0.0.1
RADIO_MONITOR_UDP_PORT=7355
RADIO_MONITOR_SAMPLE_RATE=24000

# Radio spectrum UDP settings
RADIO_SPECTRUM_UDP_HOST=127.0.0.1
RADIO_SPECTRUM_UDP_PORT=7356

# =============================================================================
# MOCK/TESTING
# =============================================================================

# Enable mock clients for testing without real APIs
MOCK_PREDICTSPRING=false
MOCK_MANHATTAN=false
