{
    "builder.serverUrl": "https://ssussf-server.tail39e95f.ts.net",
    "builder.command": "npm run start",
    "builder.runDevServer": false,
    "builder.autoDetectDevServer": true,
    "builder.launchType": "desktop",
    "chat.agent.maxRequests": 200,
    "claudeCode.preferredLocation": "sidebar"
    ,
    "github.copilot.chat.mcp": {
        "mcpServers": {
            "stockroom-inventory": {
                "command": "node",
                "args": ["inventory-server.js"],
                "cwd": "/var/www/stockroom-dashboard/mcp-servers",
                "env": {
                    "STOCKROOM_DATA_DIR": "/var/lib/stockroom-dashboard/data",
                    "STOCKROOM_FILES_DIR": "/var/lib/stockroom-dashboard/files"
                }
            },
            "stockroom-shipments": {
                "command": "node",
                "args": ["shipments-server.js"],
                "cwd": "/var/www/stockroom-dashboard/mcp-servers",
                "env": {
                    "STOCKROOM_DATA_DIR": "/var/lib/stockroom-dashboard/data"
                }
            }
        }
    },
    "chat.tools.terminal.autoApprove": {
        "pm2": true,
        "/^node scripts/import-storecount-to-postgres\\.js$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^node -c /var/www/stockroom-dashboard/src/routes/gameplan\\.js$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^node -c /var/www/stockroom-dashboard/public/js/dashboard\\.js$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^sudo -u postgres psql -d stockroom_dashboard -c \"GRANT ALL ON TABLE users TO victor; GRANT USAGE, SELECT, UPDATE ON SEQUENCE users_id_seq TO victor; GRANT ALL ON TABLE user_audit_log TO victor; GRANT USAGE, SELECT, UPDATE ON SEQUENCE user_audit_log_id_seq TO victor;\" \\| cat$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "tee": true,
        "printf": true,
        "/^node -e \"require\\('\\./utils/ups-email-parser\\.js'\\)\\.testUPSEmailFetch\\(\\)\" \\| tee -a logs/email-parser-debug\\.log$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^source \\.env && node -e \"require\\('\\./utils/ups-email-parser\\.js'\\)\\.testUPSEmailFetch\\(\\)\" \\| tee -a logs/email-parser-debug\\.log$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^sudo -u postgres psql -d stockroom_dashboard -c \"\\\\d shipments\" \\| cat$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^sudo -u postgres psql -d stockroom_dashboard -c \"SELECT id, tracking_number, customer_name, address, status_from_ups, processed_by_name FROM shipments LIMIT 5;\"$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^node -e \"require\\('\\./utils/ups-email-parser\\.js'\\)\\.testUPSEmailFetch\\(\\)\"$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^node -c server\\.js$/": {
            "approve": true,
            "matchCommandLine": true
        }
    }
}